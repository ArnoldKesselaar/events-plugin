{
  "name": "@quicklaunch/events-plugin",
  "version": "1.0.0",
  "description": "Events management plugin for React Admin applications in the Quicklaunch ecosystem",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "source": "./index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "vite build",
    "prepare": "npm run build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "preversion": "npm run type-check && npm run build",
    "postversion": "git push && git push --tags"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-admin": "^4.16.0",
    "@mui/material": "^5.14.0"
  },
  "dependencies": {
    "@mui/icons-material": "^5.14.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "date-fns": "^2.30.0",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.1.6",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "keywords": [
    "react-admin",
    "plugin",
    "events",
    "quicklaunch"
  ],
  "author": "Quicklaunch",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "internal"
  }
}
